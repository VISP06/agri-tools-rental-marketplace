# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB connection string
# Option 1: Local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/agri_tools_marketplace

# Option 2: MongoDB Atlas (cloud - recommended for teams)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/agri_tools_marketplace

# Server port
PORT=5000
